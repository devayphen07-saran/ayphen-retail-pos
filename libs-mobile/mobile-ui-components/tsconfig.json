{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "jsx": "react-native",
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "outDir": "./dist",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@ayphen/mobile-theme": ["../mobile-theme/src"],
      "@ayphen/mobile-theme/*": ["../mobile-theme/src/*"],
      "@ayphen/mobile-utils": ["../mobile-utils/src"],
      "@ayphen/mobile-utils/*": ["../mobile-utils/src/*"]
    }
  },
  "include": ["src/**/*", "../mobile-theme/src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../mobile-theme"
    }
  ]
}
