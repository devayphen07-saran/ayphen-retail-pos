auto-install-peers=true
# Pinned to isolated (pnpm's default) because the machine-wide pnpm config
# (~/Library/Preferences/pnpm/rc) sets node-linker=hoisted, which can only
# keep one version per package name at the flat root node_modules — this
# workspace needs jest-mock/jest-environment-node@30.4.1 for apps/backend
# and @29.7.0 (via jest-expo) for apps/mobile at the same time, which a
# hoisted linker cannot satisfy for both simultaneously.
node-linker=isolated
