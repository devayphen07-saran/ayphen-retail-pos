# App
NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ayphen_pos

# JWT — secrets must be at least 32 characters
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (optional — required for caching and idempotency features)
# REDIS_URL=redis://localhost:6379

# SMTP (optional — required for email features)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password
