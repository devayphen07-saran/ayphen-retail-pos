# App
NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ayphen_pos

# JWT — secrets must be at least 32 characters
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (optional — required for caching, snapshot cache, and idempotency features)
# REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# SMTP (optional — required for email features)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password

# SMS OTP (optional — required for MSG91-backed OTP delivery)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# Payments — Razorpay (optional — absent binds the Fake payment provider)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── Auth constants (all optional — sensible defaults in src/config/env.ts) ────
# OTP_TTL_SECONDS=300
# OTP_RESEND_COOLDOWN_SECONDS=60
# OTP_MAX_ATTEMPTS=5
# Per-IP backstop — loose on purpose: carrier-grade NAT puts thousands of
# legitimate users behind one IP; per-phone limits are the real abuse control.
# IP_MAX_ATTEMPTS=100
# THROTTLE_GLOBAL_LIMIT=300
# LOGIN_ATTEMPTS_RETENTION_DAYS=30
# DEVICE_CHALLENGE_TTL_SECONDS=300
# SESSION_CACHE_TTL_SECONDS=30
# REFRESH_TOKEN_TTL_SECONDS=2592000
# ACCESS_TOKEN_TTL_SECONDS=900
# SNAPSHOT_CACHE_TTL_SECONDS=604800
# STEP_UP_VALIDITY_SECONDS=300
# STEP_UP_RATE_WINDOW_SECONDS=300
# STEP_UP_MAX_ATTEMPTS=5
# MAX_PASSWORD_LENGTH=1024
# MAX_FAILED_LOGIN_ATTEMPTS=5
# ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# ── File uploads (optional) ────────────────────────────────────────────────
# UPLOAD_MAX_FILE_SIZE_MB=10
# UPLOAD_MAX_FILES_PER_REQUEST=5
# JSON_BODY_LIMIT=1mb

# ── Cron expressions (optional — configurable without redeploy) ────────────
# CRON_TOKEN_CLEANUP=0 3 * * *
# CRON_LOGIN_ATTEMPTS_CLEANUP=30 3 * * *
# CRON_DEVICE_AUTO_EXPIRY=0 3 * * *
# CRON_SUBSCRIPTION_RECONCILIATION=*/5 * * * *
# CRON_LOW_STOCK_CHECK=0 8 * * *
# CRON_PENDING_ORDER_CLEANUP=*/30 * * * *
